# ============================================================
# CapiSolutions CRM — Variáveis de Ambiente
# Copie para .env.local (desenvolvimento) ou .env (produção)
# NUNCA commite .env ou .env.local no Git
# ============================================================

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role (NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database URL (para migrações e seeds locais)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ============================================================
# APLICAÇÃO
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="CapiSolutions CRM"
NODE_ENV=development

# ============================================================
# EVOLUTION API (WhatsApp)
# ============================================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key

# ============================================================
# N8N
# ============================================================
N8N_WEBHOOK_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ============================================================
# OPENAI
# ============================================================
OPENAI_API_KEY=sk-your-openai-key

# ============================================================
# OPENROUTER
# ============================================================
OPENROUTER_API_KEY=sk-or-your-key

# ============================================================
# OLLAMA (self-hosted)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# SEGURANÇA
# ============================================================
# Chave para criptografar tokens de API armazenados no banco
ENCRYPTION_KEY=your-32-char-encryption-key-here

# JWT secret (usado pelo Supabase, não altere manualmente)
# SUPABASE_JWT_SECRET=auto-generated-by-supabase

# ============================================================
# STORAGE
# ============================================================
# Bucket padrão do Supabase Storage para arquivos
NEXT_PUBLIC_STORAGE_BUCKET=capisolutions-files

# ============================================================
# EMAIL (Supabase SMTP ou serviço externo)
# ============================================================
# Configurado no dashboard do Supabase
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=your-resend-api-key
# SMTP_FROM_EMAIL=noreply@capisolutions.com.br
# SMTP_FROM_NAME="CapiSolutions CRM"
